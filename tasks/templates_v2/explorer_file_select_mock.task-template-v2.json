{
  "schema_version": "5.4.1",
  "runtime_version": "5.8.7",
  "protocol_version": "5.4",
  "template_id": "explorer_file_select_mock",
  "required_profile": "explorer",
  "parameters": [
    { "name": "file_path", "type": "path", "required": true },
    { "name": "expected_result", "type": "string", "required": true },
    { "name": "output_region", "type": "roi", "required": true }
  ],
  "states": ["pending", "running", "waiting", "verifying", "completed", "failed", "blocked"],
  "preconditions": [
    { "type": "profile_window_scope", "value": "explicit_title_or_process_match" },
    { "type": "allowed_local_path", "parameter": "file_path" }
  ],
  "steps": [
    { "step_id": "focus_address_bar", "action": "focus", "locator_ref": "address_bar" },
    { "step_id": "enter_local_path", "action": "type_text", "locator_ref": "address_bar", "uses_parameters": ["file_path"] },
    { "step_id": "verify_file_list", "action": "verify_text", "roi_ref": "file_list", "uses_parameters": ["expected_result", "output_region"] }
  ],
  "verification": {
    "type": "profile_bound_text",
    "expected_parameter": "expected_result",
    "roi_parameter": "output_region"
  },
  "recovery": {
    "use_profile_recovery_strategy": true,
    "max_retries": 1,
    "safe_stop_on_unresolved": true
  },
  "confirmation_nodes": [
    { "name": "delete_or_overwrite_dialog", "route": "human_confirmation" }
  ],
  "final_state_policy": {
    "success_state": "completed",
    "failure_state": "failed",
    "blocked_state": "blocked",
    "profile_can_override_safety": false
  },
  "allow_unrestricted_desktop": false
}
