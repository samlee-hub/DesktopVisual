{
  "schema_version": "5.4.1",
  "runtime_version": "5.8.7",
  "protocol_version": "5.4",
  "template_id": "local_problem_page_run_read",
  "required_profile": "local_problem_page",
  "parameters": [
    { "name": "local_url", "type": "local_url", "required": true },
    { "name": "body", "type": "string", "required": true },
    { "name": "expected_result", "type": "string", "required": true },
    { "name": "output_region", "type": "roi", "required": true }
  ],
  "states": ["pending", "running", "waiting", "verifying", "completed", "failed", "blocked"],
  "preconditions": [
    { "type": "profile_window_scope", "value": "local_fixture_only" },
    { "type": "not_public_assessment", "value": true }
  ],
  "steps": [
    { "step_id": "load_problem_fixture", "action": "open_local_html", "uses_parameters": ["local_url"], "roi_ref": "problem_statement" },
    { "step_id": "fill_answer", "action": "type_text", "locator_ref": "answer_box", "uses_parameters": ["body"] },
    { "step_id": "run_check", "action": "click", "locator_ref": "check_button" },
    { "step_id": "read_result", "action": "verify_text", "roi_ref": "answer_area", "uses_parameters": ["expected_result", "output_region"] }
  ],
  "verification": {
    "type": "profile_bound_text",
    "expected_parameter": "expected_result",
    "roi_parameter": "output_region"
  },
  "recovery": {
    "use_profile_recovery_strategy": true,
    "max_retries": 1,
    "safe_stop_on_unresolved": true
  },
  "confirmation_nodes": [
    { "name": "submit_assessment", "route": "stop" }
  ],
  "final_state_policy": {
    "success_state": "completed",
    "failure_state": "failed",
    "blocked_state": "blocked",
    "profile_can_override_safety": false
  },
  "allow_unrestricted_desktop": false
}
