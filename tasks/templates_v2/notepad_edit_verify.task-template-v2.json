{
  "schema_version": "5.4.1",
  "runtime_version": "5.8.7",
  "protocol_version": "5.4",
  "template_id": "notepad_edit_verify",
  "required_profile": "notepad",
  "parameters": [
    { "name": "body", "type": "string", "required": true },
    { "name": "expected_result", "type": "string", "required": true },
    { "name": "output_region", "type": "roi", "required": true }
  ],
  "states": ["pending", "running", "verifying", "completed", "failed", "blocked"],
  "preconditions": [
    { "type": "profile_window_scope", "value": "explicit_title_or_process_match" }
  ],
  "steps": [
    { "step_id": "edit_text", "action": "type_text", "locator_ref": "edit_area", "uses_parameters": ["body"] },
    { "step_id": "verify_text", "action": "verify_text", "roi_ref": "editor", "uses_parameters": ["expected_result", "output_region"] }
  ],
  "verification": {
    "type": "profile_bound_text",
    "expected_parameter": "expected_result",
    "roi_parameter": "output_region"
  },
  "recovery": {
    "use_profile_recovery_strategy": true,
    "max_retries": 1,
    "safe_stop_on_unresolved": true
  },
  "confirmation_nodes": [
    { "name": "save_prompt", "route": "human_confirmation" }
  ],
  "final_state_policy": {
    "success_state": "completed",
    "failure_state": "failed",
    "blocked_state": "blocked",
    "profile_can_override_safety": false
  },
  "allow_unrestricted_desktop": false
}
