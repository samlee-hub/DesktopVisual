{
  "schema_version": "5.4.1",
  "runtime_version": "5.8.7",
  "protocol_version": "5.4",
  "template_id": "local_mail_mock_compose_attach_no_real_send",
  "required_profile": "local_mail_mock",
  "parameters": [
    { "name": "recipient", "type": "string", "required": true },
    { "name": "subject", "type": "string", "required": true },
    { "name": "body", "type": "string", "required": true },
    { "name": "file_path", "type": "path", "required": true },
    { "name": "expected_result", "type": "string", "required": true },
    { "name": "output_region", "type": "roi", "required": true }
  ],
  "states": ["pending", "running", "waiting", "verifying", "confirmed", "completed", "failed", "blocked"],
  "preconditions": [
    { "type": "profile_window_scope", "value": "local_fixture_only" },
    { "type": "no_real_send", "value": true }
  ],
  "steps": [
    { "step_id": "open_compose", "action": "click", "locator_ref": "compose_button" },
    { "step_id": "enter_recipient", "action": "type_text", "roi_ref": "compose_area", "uses_parameters": ["recipient"] },
    { "step_id": "enter_subject", "action": "type_text", "roi_ref": "compose_area", "uses_parameters": ["subject"] },
    { "step_id": "enter_body", "action": "type_text", "roi_ref": "compose_area", "uses_parameters": ["body"] },
    { "step_id": "attach_local_file", "action": "file_picker_flow", "roi_ref": "attachment_area", "uses_parameters": ["file_path"] },
    { "step_id": "verify_upload", "action": "upload_verification", "roi_ref": "attachment_area", "uses_parameters": ["file_path"] },
    { "step_id": "verify_no_real_send", "action": "verify_text", "roi_ref": "send_button_area", "uses_parameters": ["expected_result", "output_region"] },
    { "step_id": "mock_send_only", "action": "click", "locator_ref": "mock_send_button", "confirmation_node": "external_attachment" }
  ],
  "verification": {
    "type": "profile_bound_text",
    "expected_parameter": "expected_result",
    "roi_parameter": "output_region",
    "upload_verification": true,
    "no_real_send": true
  },
  "recovery": {
    "use_profile_recovery_strategy": true,
    "max_retries": 1,
    "safe_stop_on_unresolved": true
  },
  "confirmation_nodes": [
    { "name": "external_attachment", "route": "human_confirmation" }
  ],
  "final_state_policy": {
    "success_state": "completed",
    "failure_state": "failed",
    "blocked_state": "blocked",
    "profile_can_override_safety": false
  },
  "allow_unrestricted_desktop": false
}
